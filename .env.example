# ==================== AI求职助手 - 环境变量配置模板 ====================
# 使用说明：
#   1. 复制此文件为 deep_research/.env
#   2. 填入你的真实 API Key
#   3. 运行 python -m deep_research 或 bash run.sh
#
# 注意：此文件不应包含真实 Key，请勿提交到公开仓库。

# ==================== LLM 供应商切换 ====================
# 可选值: deepseek | dashscope
LLM_PROVIDER=deepseek

# ==================== DeepSeek 配置（当 LLM_PROVIDER=deepseek 时） ====================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.7

# ==================== DashScope 阿里云通义千问配置（当 LLM_PROVIDER=dashscope 时） ====================
# DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ==================== Bocha 搜索 API ====================
BOCHA_API_KEY=sk-your-bocha-api-key-here

# ==================== GitHub API Token（可选，提高搜索配额） ====================
# 无 Token 限制：60次/小时（搜索受限）
# 有 Token 限制：5000次/小时
# 获取方式：https://github.com/settings/tokens → Generate new token (classic)
# 权限需求：无需勾选任何额外权限（仅用于公开仓库搜索）
GITHUB_API_KEY=ghp_your_github_personal_access_token_here

# ==================== MCP (Model Context Protocol) 配置 ====================
# MCP 总开关 — 设为 false 禁用所有 MCP Server
MCP_ENABLED=true

# GitHub MCP Server — 通过 MCP 协议精准查询 GitHub 仓库、README、Issues
# 前置依赖：Node.js (>=18) + npx
# 安装: npm install -g npx（通常随 Node.js 自带）
# Token: 复用上方 GITHUB_API_KEY 或单独设置
MCP_GITHUB_ENABLED=true
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_personal_access_token_here

# MCP 搜索策略: mcp_first（MCP优先，回退传统API）| traditional（仅传统API）| mcp_only（仅MCP）
MCP_SEARCH_STRATEGY=mcp_first

# Brave Search MCP Server（预留，后续扩展英文技术资料搜索）
# MCP_BRAVE_ENABLED=false
# BRAVE_API_KEY=your-brave-api-key
